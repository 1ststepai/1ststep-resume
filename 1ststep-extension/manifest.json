{
  "manifest_version": 3,
  "name": "1stStep.ai - Job Application Assistant",
  "version": "0.1.0",
  "description": "Tailor your resume and auto-fill applications in 1 click. LinkedIn, Indeed, Greenhouse, Lever, Workday, and more.",
  "permissions": [
    "storage",
    "scripting",
    "activeTab",
    "sidePanel"
  ],
  "host_permissions": [
    "https://www.linkedin.com/*",
    "https://www.indeed.com/*",
    "https://boards.greenhouse.io/*",
    "https://jobs.lever.co/*",
    "https://jobs.lever.com/*",
    "https://*.workday.com/*",
    "https://*.icims.com/*",
    "https://*.taleo.net/*",
    "https://app.1ststep.ai/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "1stStep.ai - Resume Tailor & Apply"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.linkedin.com/*",
        "https://www.indeed.com/*",
        "https://boards.greenhouse.io/*",
        "https://jobs.lever.co/*",
        "https://jobs.lever.com/*",
        "https://*.workday.com/*",
        "https://*.icims.com/*",
        "https://*.taleo.net/*"
      ],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "web_accessible_resources": [
    {
      "resources": ["sites/*.js", "utils/*.js"],
      "matches": ["<all_urls>"]
    }
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
