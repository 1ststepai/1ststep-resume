{
  "manifest_version": 3,
  "name": "1stStep.ai - Job Application Assistant",
  "version": "0.1.0",
  "description": "Tailor your resume and auto-fill applications in 1 click. LinkedIn, Indeed, Greenhouse, Lever, Workday, and more.",
  "permissions": [
    "storage",
    "scripting",
    "activeTab",
    "sidePanel",
    "tabs"
  ],
  "host_permissions": [
    "https://www.linkedin.com/*",
    "https://www.indeed.com/*",
    "https://*.greenhouse.io/*",
    "https://*.lever.co/*",
    "https://*.lever.com/*",
    "https://*.workday.com/*",
    "https://*.myworkdayjobs.com/*",
    "https://*.icims.com/*",
    "https://*.taleo.net/*",
    "https://*.ashbyhq.com/*",
    "https://*.jobvite.com/*",
    "https://*.smartrecruiters.com/*",
    "https://app.1ststep.ai/*"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  },
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "1stStep.ai - Resume Tailor & Apply"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.linkedin.com/*",
        "https://www.indeed.com/*",
        "https://*.greenhouse.io/*",
        "https://*.lever.co/*",
        "https://*.lever.com/*",
        "https://*.workday.com/*",
        "https://*.myworkdayjobs.com/*",
        "https://*.icims.com/*",
        "https://*.taleo.net/*",
        "https://*.ashbyhq.com/*",
        "https://*.jobvite.com/*",
        "https://*.smartrecruiters.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://app.1ststep.ai/*"],
      "js": ["auth-bridge.js"],
      "run_at": "document_idle"
    }
  ],
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "web_accessible_resources": [
    {
      "resources": ["sites/*.js", "utils/*.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
