# 1stStep.ai - Environment Variables
#
# DO NOT commit a real .env file. Set these in Vercel:
#   Project > Settings > Environment Variables
#
# Required for generation:
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here
#
# Required for paid launch:
STRIPE_SECRET_KEY=sk_live_your-live-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-live-webhook-secret
TIER_SECRET=generate-a-long-random-secret
BETA_MODE=false

# Optional owner restore access.
# Do not put these values in frontend code. Use a long random OWNER_ACCESS_SECRET.
OWNER_ACCESS_EMAILS=owner@example.com
OWNER_ACCESS_SECRET=generate-a-long-random-owner-restore-code

# Required for passwordless subscription restore emails.
RESEND_API_KEY=re_your-resend-key
RESEND_FROM=1stStep.ai <support@1ststep.ai>
#
# Stripe live launch notes:
# - Use live-mode products/prices for Job Hunt Pass ($24.99/month).
# - Register the live webhook endpoint separately from any test endpoint.
# - Configure checkout success/cancel URLs for the production domain.
#
# Cost estimate per generation:
#   Resume only: ~$0.06-0.10
#   Resume + cover letter: ~$0.12-0.18

# LinkedIn OAuth (Sign In with LinkedIn using OpenID Connect)
# Create app at: https://www.linkedin.com/developers/apps
# Add product: "Sign In with LinkedIn using OpenID Connect"
# Set redirect URL to: https://app.1ststep.ai/api/subscription?action=linkedin-callback
LINKEDIN_CLIENT_ID=your-client-id-here
LINKEDIN_CLIENT_SECRET=your-client-secret-here

# Optional: Agent Analytics product analytics.
# These values are public tracker config returned by /api/app-config.
# Hosted agentanalytics.sh domains are allowed in vercel.json CSP.
# If you self-host on another domain, add that domain to script-src/connect-src.
AGENT_ANALYTICS_URL=https://your-agent-analytics-host.example.com
AGENT_ANALYTICS_PROJECT=1ststep-app
AGENT_ANALYTICS_TOKEN=your-public-project-token
